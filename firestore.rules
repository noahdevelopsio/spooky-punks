/**
 * @fileoverview Firestore Security Rules for Spooky Punks Application
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for PumpkinTokens. Each user can only
 * access their own tokens.  Data is denormalized to enable simple, performant rules.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data.
 * - /users/{userId}/pumpkin_tokens/{tokenId}: Stores PumpkinToken data owned by the user. Each token
 *   document contains a denormalized userId field.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own PumpkinTokens.
 * - Listing all users is disallowed.
 * - Data required for authorization is denormalized onto the documents being secured.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profiles.
     * @path /users/{userId}
     * @allow (create) User 'user_abc' can create their own profile.
     * @deny (create) User 'user_abc' cannot create a profile for 'user_xyz'.
     * @allow (get) User 'user_abc' can read their own profile.
     * @deny (get) User 'user_abc' cannot read profile of 'user_xyz'.
     * @principle Enforces document ownership for writes and reads.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow list: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Secure PumpkinTokens owned by a specific user.
     * @path /users/{userId}/pumpkin_tokens/{tokenId}
     * @allow (create) User 'user_abc' can create a token under their user ID.
     * @deny (create) User 'user_abc' cannot create a token under user ID 'user_xyz'.
     * @allow (get) User 'user_abc' can read their own token.
     * @deny (get) User 'user_abc' cannot read a token owned by 'user_xyz'.
     * @principle Enforces document ownership for writes and reads, and validates data consistency.
     */
    match /users/{userId}/pumpkin_tokens/{tokenId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}